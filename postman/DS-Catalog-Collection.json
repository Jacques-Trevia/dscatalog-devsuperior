							"listen": "test",
							"script": {
								"exec": [
									"if (responseCode.code >= 200 && responseCode.code < 300) {\r",
									"   var json = JSON.parse(responseBody);\r",
									"   postman.setEnvironmentVariable('token', json.access_token);\r",
